{
  "$schema": "https://json.schemastore.org/swcrc",
  "jsc": {
    "baseUrl": ".",
    "parser": {
      "syntax": "typescript",
      "decorators": true,
      "dynamicImport": true
    },
    "transform": {
      "decoratorMetadata": true,
      "legacyDecorator": true
    },
    "paths": {
      "@app/*": [
        "./*"
      ],
      "@database/*": [
        "./database/*"
      ],
      "@module/*": [
        "./modules/*"
      ],
      "@jest/*": [
        "./@jest/*"
      ]
    },
    "target": "es2022"
  }
}
