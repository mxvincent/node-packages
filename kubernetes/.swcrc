{
  "$schema": "https://json.schemastore.org/swcrc",
  "module": {
    "type": "commonjs"
  },
  "sourceMaps": false,
  "jsc": {
    "loose": false,
    "baseUrl": "./src",
    "parser": {
      "syntax": "typescript",
      "dynamicImport": true
    },
    "paths": {
      "#/*": [
        "./*"
      ]
    },
    "target": "es2020"
  }
}
