{
	"name": "node-packages",
	"packageManager": "pnpm@9.15.3+sha512.1f79bc245a66eb0b07c5d4d83131240774642caaa86ef7d0434ab47c0d16f66b04e21e0c086eb61e62c77efc4d7f7ec071afad3796af64892fae66509173893a",
	"engines": {
		"node": ">=22.12"
	},
	"scripts": {
		"build:swc": "turbo run build:swc",
		"build:tsc": "turbo run build:tsc",
		"build:actions": "turbo run build:swc --filter='@action/*'",
		"build:packages": "turbo run build:swc --filter='./packages/*'",
		"clean": "rm -rf out && turbo run clean --parallel",
		"changeset": "changeset add",
		"changeset:bump": "changeset version",
		"changeset:tag": "changeset tag",
		"code:check": "turbo run code:check",
		"code:format": "prettier --write \"**/*.{ts,tsx,md}\" && turbo run code:lint -- --fix",
		"code:lint": "turbo run code:lint",
		"modules:clean": "find . -name \"node_modules\" -type d -prune -exec rm -rf '{}' +",
		"modules:info": "find . -name \"node_modules\" -type d -prune | xargs du -chs",
		"modules:install": "pnpm run modules:clean && pnpm install",
		"preinstall": "npx only-allow pnpm",
		"prepare": "is-ci || husky",
		"test:all": "turbo run test:all",
		"docker-build": "CI=true ./scripts/docker-build.sh"
	},
	"devDependencies": {
		"@changesets/changelog-github": "^0.5.0",
		"@changesets/cli": "^2.27.11",
		"@commitlint/config-conventional": "^19.5.0",
		"@eslint/js": "^9.13.0",
		"@swc/cli": "^0.6.0",
		"@swc/core": "^1.10.7",
		"@swc/jest": "^0.2.36",
		"@swc-node/register": "^1.10.9",
		"@types/jest": "^29.5.14",
		"@types/node": "^20.17.0",
		"commitlint": "^19.5.0",
		"dotenv": "^16.4.5",
		"eslint": "^9.18.0",
		"eslint-plugin-import": "^2.31.0",
		"globals": "^15.11.0",
		"husky": "^9.1.6",
		"is-ci": "^3.0.1",
		"jest": "^29.7.0",
		"prettier": "^3.3.3",
		"tsc-alias": "^1.8.10",
		"turbo": "^2.3.1",
		"typescript": "^5.6.3",
		"typescript-eslint": "^8.20.0"
	}
}
