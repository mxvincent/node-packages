{
	"name": "@mxvincent/telemetry",
	"version": "0.1.1",
	"private": true,
	"main": "./dist/index.js",
	"types": "./src/index.ts",
	"source": "./src/index.ts",
	"exports": {
		".": "./dist/index.js",
		"./register": "./dist/register.js"
	},
	"scripts": {
		"build:tsc": "tsc",
		"build:swc": "swc ./src -d ./dist --strip-leading-paths",
		"build:swc:watch": "pnpm run build:swc --watch",
		"clean": "find . ! -path '*/node_modules/*' -name 'dist' -d -prune -exec rm -rf '{}' +; find . -name '*.tsbuildinfo' -prune -exec rm -rf '{}' +; find . -path '*/.turbo' -type d -prune -exec rm -rf '{}' +",
		"code:lint": "eslint",
		"code:check": "tsc --noEmit",
		"code:check-watch": "tsc --noEmit --watch"
	},
	"dependencies": {
		"@mxvincent/json-schema": "workspace:*",
		"@opentelemetry/api": "^1.9.0",
		"@opentelemetry/exporter-metrics-otlp-proto": "^0.57.0",
		"@opentelemetry/exporter-trace-otlp-http": "^0.57.0",
		"@opentelemetry/exporter-trace-otlp-proto": "^0.57.0",
		"@opentelemetry/instrumentation": "^0.57.0",
		"@opentelemetry/instrumentation-amqplib": "^0.40.0",
		"@opentelemetry/instrumentation-dns": "^0.39.0",
		"@opentelemetry/instrumentation-fastify": "^0.39.0",
		"@opentelemetry/instrumentation-http": "^0.57.0",
		"@opentelemetry/instrumentation-net": "^0.43.0",
		"@opentelemetry/instrumentation-pg": "^0.49.0",
		"@opentelemetry/instrumentation-pino": "^0.46.0",
		"@opentelemetry/otlp-exporter-base": "^0.57.0",
		"@opentelemetry/resource-detector-container": "^0.5.3",
		"@opentelemetry/resources": "^1.30.0",
		"@opentelemetry/sdk-metrics": "^1.29.0",
		"@opentelemetry/sdk-node": "^0.52.1",
		"@opentelemetry/sdk-trace-base": "^1.30.0",
		"@opentelemetry/sdk-trace-node": "^1.29.0",
		"@opentelemetry/semantic-conventions": "^1.28.0",
		"opentelemetry-instrumentation-sequelize": "^0.41.0",
		"opentelemetry-instrumentation-typeorm": "^0.41.0",
		"pino": "^9.3.2",
		"pino-std-serializers": "^7.0.0"
	},
	"devDependencies": {
		"@mxvincent/eslint-config": "workspace:*",
		"@mxvincent/tsconfig": "workspace:*",
		"pino-pretty": "^11.3.0"
	}
}
