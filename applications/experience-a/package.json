{
	"name": "experience-a",
	"version": "0.1.1",
	"private": true,
	"main": "./dist/index.js",
	"types": "./src/index.ts",
	"scripts": {
		"build:swc": "swc ./src -d ./dist --strip-leading-paths",
		"build:tsc": "tsc",
		"build:watch": "pnpm run build:swc --watch",
		"clean": "find . ! -path '*/node_modules/*' -name 'dist' -d -prune -exec rm -rf '{}' +; find . -name '*.tsbuildinfo' -prune -exec rm -rf '{}' +; find . -path '*/.turbo' -type d -prune -exec rm -rf '{}' +",
		"code:lint": "eslint",
		"code:check": "tsc --noEmit",
		"code:check:watch": "tsc --noEmit --watch",
		"start:app-server": "node --watch  -r tsconfig-paths/register -r dotenv/config -r @swc-node/register  src/app-server.ts",
		"start:seed-database": "node -r reflect-metadata -r tsconfig-paths/register -r dotenv/config -r @swc-node/register src/scripts/database-seed.ts",
		"start:sandbox": "node -r reflect-metadata -r tsconfig-paths/register -r dotenv/config -r @swc-node/register src/scripts/sandbox.ts",
		"test:all": "jest",
		"test:all:watch": "jest --watch"
	},
	"dependencies": {
		"@apollo/server": "4.9.3",
		"@faker-js/faker": "^8.0.2",
		"@mxvincent/core": "workspace:*",
		"@mxvincent/json-schema": "workspace:*",
		"@mxvincent/query-params": "workspace:*",
		"@mxvincent/telemetry": "workspace:*",
		"@mxvincent/typeorm": "workspace:*",
		"@nestjs/apollo": "^12.0.3",
		"@nestjs/common": "^9.4.2",
		"@nestjs/core": "^9.4.2",
		"@nestjs/graphql": "^12.0.3",
		"@nestjs/platform-express": "^10.0.3",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.14.0",
		"graphql": "^16.7.1",
		"graphql-fields": "^2.0.3",
		"nestjs-pino": "^3.3.0",
		"pg": "^8.11.0",
		"ramda": "^0.29.0",
		"reflect-metadata": "^0.1.13",
		"tiny-invariant": "^1.3.1",
		"tsconfig-paths": "^4.2.0",
		"typeorm": "^0.3.17"
	},
	"devDependencies": {
		"@mxvincent/eslint-config": "workspace:*",
		"@mxvincent/tsconfig": "workspace:*",
		"@types/graphql-fields": "^1.3.5",
		"@types/ramda": "^0.29.2"
	}
}
