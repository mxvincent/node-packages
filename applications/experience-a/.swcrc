{
  "$schema": "https://swc.rs/schema.json",
  "module": {
    "type": "commonjs"
  },
  "jsc": {
    "baseUrl": "./src",
    "parser": {
      "syntax": "typescript",
      "decorators": true,
      "dynamicImport": true
    },
    "transform": {
      "decoratorMetadata": true,
      "legacyDecorator": true
    },
    "paths": {
      "#/*": [
        "./*"
      ],
      "#/jest/*": [
        "./@jest/*"
      ]
    },
    "target": "es2020"
  }
}
