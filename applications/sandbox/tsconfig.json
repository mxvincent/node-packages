{
	"extends": "@mxvincent/tsconfig/commonjs.json",
	"include": ["src"],
	"exclude": ["*.test.ts", "*.stub.ts", "node_modules"],
	"compilerOptions": {
		"strict": true,
		"rootDir": "./src",
		"baseUrl": "./src",
		"outDir": "./dist",
		"module": "ESNext",
		"paths": {
			"@/*": ["./*"],
			"@api/*": ["./api/*"],
			"@database/*": ["./database/*"]
		}
	}
}
