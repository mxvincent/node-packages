{
  "extends": "@mxvincent/typescript-config/node16.json",
  "include": [
    "./src"
  ],
  "exclude": [
    "**/node_modules/**"
  ],
  "compilerOptions": {
    "composite": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "experimentalDecorators": true
  },
  "ts-node": {
    "swc": true
  },
  "references": [
